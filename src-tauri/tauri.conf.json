{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "plaw-desktop",
  "version": "0.1.0",
  "identifier": "com.plaw.desktop",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5800",
    "beforeDevCommand": { "script": "pnpm dev", "cwd": "../web" },
    "beforeBuildCommand": { "script": "pnpm build", "cwd": "../web" }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Plaw",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: https://asset.localhost; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost ws://127.0.0.1:* wss://127.0.0.1:* http://127.0.0.1:* https://127.0.0.1:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {},
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
